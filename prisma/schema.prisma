// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  avatar    String?
  bio       String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// English-Vietnamese vocabulary pairs for flashcard learning
model Vocabulary {
  id              Int     @id @default(autoincrement())
  english         String
  vietnamese      String
  pronunciation   String? /// IPA or phonetic spelling
  exampleEnglish  String? @map("example_english") /// Example sentence in English
  exampleVietnamese String? @map("example_vietnamese") /// Example sentence in Vietnamese
  partOfSpeech    String? @map("part_of_speech") /// noun, verb, adjective, etc.
  difficultyLevel Int     @default(1) @map("difficulty_level") /// 1=beginner, 2=intermediate, 3=advanced
  category        String? /// topic category: food, travel, etc.
  audioUrl        String? @map("audio_url")
  imageUrl        String? @map("image_url")
  createdAt       DateTime @default(now()) @map("created_at")

  reviewLogs ReviewLog[]

  @@map("vocabulary")
}

/// Spaced repetition review logs - primary data source for ML model
/// Stores every review attempt with SM-2 algorithm parameters
model ReviewLog {
  id             Int      @id @default(autoincrement())
  userId         String   @map("user_id") /// User ID from NextAuth
  vocabularyId   Int      @map("vocabulary_id")

  // SM-2 Algorithm Parameters
  rating         Int      /// 1=Again, 2=Hard, 3=Good, 4=Easy
  easeFactor     Float    @default(2.5) @map("ease_factor") /// SM-2 ease factor (>=1.3)
  intervalDays   Int      @default(0) @map("interval_days") /// Days until next review
  repetitions    Int      @default(0) /// Number of successful repetitions

  // Timing data
  reviewedAt     DateTime @default(now()) @map("reviewed_at")
  nextReviewAt   DateTime? @map("next_review_at") /// Scheduled next review time
  responseTimeMs Int?     @map("response_time_ms") /// Time taken to answer in ms

  // Review context
  direction      String   @default("en_to_vi") /// en_to_vi or vi_to_en
  sessionId      String?  @map("session_id") /// Study session identifier
  userAnswer     String?  @map("user_answer") /// User's typed answer for auto-grading
  autoRating     Boolean? @map("auto_rating") /// Whether the rating was auto-generated

  vocabulary     Vocabulary @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@index([userId, vocabularyId], map: "idx_review_user_vocab")
  @@index([userId, nextReviewAt], map: "idx_review_user_next")
  @@index([userId, reviewedAt], map: "idx_review_user_reviewed")
  @@map("review_log")
}
